# --- Server ---
PORT=3000
DEFAULT_CHAIN=algorand-mainnet

# Optional: if set, POST /webhook/repay*, /webhook/keeperhub/repay* require x-api-key or Authorization: Bearer <key>.
# WEBHOOK_API_KEY=one-secret
# WEBHOOK_API_KEYS=key-a,key-b,key-c

# --- Algorand (shared; per-chain overrides use prefixes below) ---
ALGOD_SERVER=https://mainnet-api.4160.nodely.dev
ALGOD_PORT=443
ALGOD_TOKEN=

INDEXER_SERVER=https://mainnet-idx.4160.nodely.dev
INDEXER_PORT=443
INDEXER_TOKEN=

# Optional per-chain overrides (examples):
# TESTNET_ALGOD_SERVER=https://testnet-api.algonode.cloud
# VOI_MAINNET_ALGOD_SERVER=
# VOI_TESTNET_ALGOD_SERVER=

# When set, repay builds always use this account as payer (ARC-200 / fees / repay_on_behalf sender);
# body payerAddress is ignored. Execute mode signs with this mnemonic. Omit for unsigned self-repay
# where payer defaults from webhook payerAddress or userAddress.
SERVER_SIGNER_MNEMONIC=

# Lending pool app id: global borrow index lives here (debt simulation; optional foreign app on repay when != market).
# Example mainnet: 3333688282 (Algorand A pool); pair with USDC market app 3210682240 in GET /pools/.../markets/.../debt/...
DORKFI_LENDING_POOL_APP_ID=

# Debt preview uses lending pool ABI simulation (get_market / get_user); no TEAL key env vars required.

# Optional extra base units added on top of full debt when repayMode=max.
REPAY_MAX_BUFFER_BASE_UNITS=0

# --- Base payment gate ---
BASE_RPC_URL=https://mainnet.base.org
# Base payee (your wallet). Never leave as 0x000…0000.
PAYMENT_RECEIVER_ADDRESS=0x344621377ad7D494C0B067f0237164829Cac0258
# Base USDC for typical repay; use NATIVE or leave unset only for native ETH (not 0x000… as a placeholder).
PAYMENT_TOKEN_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# Required amount: wei for ETH, or token smallest units for ERC-20 (USDC has 6 decimals; 1000000 = 1 USDC).
REQUIRED_PAYMENT_AMOUNT=1000000
# Max seconds between payment block time and server time; 0 disables the check (any age).
PAYMENT_MAX_AGE_SECONDS=60
