# --- Server ---
PORT=3000
DEFAULT_CHAIN=algorand-mainnet

# --- Algorand (shared; per-chain overrides use prefixes below) ---
ALGOD_SERVER=https://mainnet-api.algonode.cloud
ALGOD_PORT=443
ALGOD_TOKEN=

INDEXER_SERVER=https://mainnet-idx.algonode.cloud
INDEXER_PORT=443
INDEXER_TOKEN=

# Optional per-chain overrides (examples):
# TESTNET_ALGOD_SERVER=https://testnet-api.algonode.cloud
# VOI_MAINNET_ALGOD_SERVER=
# VOI_TESTNET_ALGOD_SERVER=

# Execute mode: mnemonic must derive the same address as userAddress in the webhook body.
SERVER_SIGNER_MNEMONIC=

# Optional lending pool app for sync_market placeholder txn (must differ from market app id).
DORKFI_LENDING_POOL_APP_ID=

# UTF-8 TEAL global/local keys for borrow index and scaled borrows (required for debt math).
DORKFI_BORROW_INDEX_GLOBAL_KEY=
DORKFI_SCALED_BORROW_LOCAL_KEY=

# Optional extra base units added on top of full debt when repayMode=max.
REPAY_MAX_BUFFER_BASE_UNITS=0

# --- Base payment gate ---
BASE_RPC_URL=https://mainnet.base.org
PAYMENT_RECEIVER_ADDRESS=0x0000000000000000000000000000000000000000
# ERC-20 contract on Base, or leave empty / NATIVE / 0x000…0000 for native ETH.
PAYMENT_TOKEN_ADDRESS=NATIVE
# Required amount: wei for ETH, or smallest token units for ERC-20 (base-10 integer string).
REQUIRED_PAYMENT_AMOUNT=1
PAYMENT_MAX_AGE_SECONDS=60
